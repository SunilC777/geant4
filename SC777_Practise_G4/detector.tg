:rotm r000 0 0 0

:solid World BOX 600 200 200
:volu worldVol World G4_AIR
:vis worldVol OFF

:solid AirBox BOX 80 80 80
:volu airVol AirBox G4_AIR
:color airVol 0.7 0.9 1.0
:place airVol 0 worldVol r000 -200 0 0

:solid WaterBox BOX 80 80 80
:volu waterVol WaterBox G4_WATER
:color waterVol 0.2 0.4 1.0
:place waterVol 0 worldVol r000 0 0 0

:solid LeadBox BOX 80 80 80
:volu leadVol LeadBox G4_Pb
:color leadVol 0.5 0.5 0.5
:place leadVol 0 worldVol r000 200 0 0