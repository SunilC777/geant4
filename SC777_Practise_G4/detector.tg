:volu world BOX 6*m 2*m 2*m G4_Galactic
:vis world OFF

:volu air   BOX 10*cm 10*cm 10*cm G4_AIR
:volu water BOX 10*cm 10*cm 10*cm G4_WATER
:volu lead  BOX 10*cm 10*cm 10*cm G4_Pb

:rotm r000 0 0 0

:place air   1 world r000 -30*cm 0 0
:place water 1 world r000   0    0 0
:place lead  1 world r000  30*cm 0 0

:color air   0.60 0.80 1.00
:color water 0.20 0.40 1.00
:color lead  0.60 0.60 0.60